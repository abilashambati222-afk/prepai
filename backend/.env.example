# PrepAI Backend - Environment Variables Template
# Copy this file to .env in your local development workspace

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configurations
# Replace this with your local instance or MongoDB Atlas Connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/prepai?retryWrites=true&w=majority

# Client URLs (for CORS whitelist)
CLIENT_URL=http://localhost:5173

# Authentications (JWT)
# Use a strong secret string to sign payload keys
JWT_SECRET=prepai_super_secret_signing_key_change_me_in_production
JWT_EXPIRES_IN=7d

# Third-Party Integrations (Phases 3 & 4)
# Generate your key via Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here
